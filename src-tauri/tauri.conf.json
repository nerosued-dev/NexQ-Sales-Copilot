{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "NexQ",
  "version": "2.20.10",
  "identifier": "com.nexq.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "launcher",
        "title": "NexQ",
        "width": 900,
        "height": 650,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "NexQ Overlay",
        "width": 500,
        "height": 700,
        "minWidth": 400,
        "minHeight": 480,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "transparent": true,
        "shadow": false,
        "x": 50,
        "y": 50
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "NexQ — AI Meeting Assistant",
      "menuOnLeftClick": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "nsis-header.bmp",
        "sidebarImage": "nsis-sidebar.bmp",
        "installerHooks": "./nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMzM0VGQzk0QTQwN0UyOUEKUldTYTRnZWtsUHcrTXcxenlTdlRkZGVtWEgwVUZlMmZxOWRzNktwWGZFeWxCVGY5R2Jycml2bFIK",
      "endpoints": [
        "https://github.com/VahidAlizadeh/NexQ/releases/latest/download/latest.json"
      ]
    }
  }
}
